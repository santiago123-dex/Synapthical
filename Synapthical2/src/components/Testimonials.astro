---
const testimonials = [
  {
    quote:
      'Volví a correr después de una lesión de rodilla que ya había intentado resolver sin éxito. En AXIAL entendieron qué patrón estaba fallando y me devolvieron seguridad paso a paso.',
    name: 'Daniela Rojas',
    detail: 'Corredora amateur · rehabilitación de rodilla',
    offset: 'lg:translate-y-10',
  },
  {
    quote:
      'Trabajo muchas horas sentado y el dolor cervical ya afectaba mi sueño. El tratamiento no se quedó en aliviar: me enseñó cómo moverme y cargar mejor durante el día.',
    name: 'Felipe Torres',
    detail: 'Director creativo · terapia postural y cervical',
    offset: 'lg:-translate-y-6',
  },
  {
    quote:
      'Después de cirugía necesitaba una recuperación exigente pero segura. Sentí una combinación poco común: método, seguimiento y una atención muy humana en cada sesión.',
    name: 'Mariana Peña',
    detail: 'Paciente postquirúrgica · retorno funcional progresivo',
    offset: 'lg:translate-y-16',
  },
];
---

<section class="relative py-24 sm:py-28 lg:py-36">
  <div class="section-shell">
    <div class="reveal-view max-w-3xl">
      <span class="section-kicker">Testimonios</span>
      <h2 class="section-title mt-6">La recuperación se siente distinta cuando alguien sabe leer tu movimiento.</h2>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3 lg:gap-5">
      {testimonials.map((testimonial) => (
        <figure class:list={[
          'reveal-view surface-panel rounded-[1.75rem] px-6 py-7 sm:px-7 sm:py-8',
          testimonial.offset,
        ]}>
          <div class="quote-mark">“</div>
          <blockquote class="mt-3 text-lg leading-8 text-secondary/95">
            {testimonial.quote}
          </blockquote>
          <figcaption class="mt-8 border-t border-(--axial-border) pt-5">
            <cite class="not-italic font-display text-[1.35rem] tracking-[-0.04em] text-secondary">{testimonial.name}</cite>
            <p class="mt-2 text-sm uppercase tracking-[0.22em] text-(--axial-muted)">{testimonial.detail}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
