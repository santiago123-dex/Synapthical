<section id="contacto" class="px-0 pb-14 pt-8 sm:pb-16 sm:pt-10 lg:pb-20">
  <div class="section-shell">
    <div class="surface-panel rounded-[2rem] px-6 py-10 sm:px-8 sm:py-12 lg:px-12 lg:py-14">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,0.86fr)_minmax(18rem,1.14fr)] lg:items-stretch lg:gap-10">
        <div class="reveal-view">
          <span class="section-kicker">Contacto</span>
          <h2 class="section-title mt-6 max-w-xl">
            Agenda tu próxima sesión.
          </h2>
          <p class="section-copy mt-5 max-w-md">
            Escríbenos, llámanos o visítanos en Bogotá.
          </p>
          <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
            <a href="mailto:hola@axialfisioterapia.co" class="btn-primary">Escríbenos</a>
            <a href="tel:+573001234567" class="btn-secondary">Llamar</a>
          </div>
          <div class="mt-8 grid gap-5 border-t border-[color:var(--axial-border)] pt-6">
            <div>
              <p class="text-sm uppercase tracking-[0.24em] text-[color:var(--axial-muted)]">Correo</p>
              <a href="mailto:hola@axialfisioterapia.co" class="contact-link mt-2 inline-block font-display text-[1.25rem] tracking-[-0.03em] text-secondary">
                hola@axialfisioterapia.co
              </a>
            </div>
            <div>
              <p class="text-sm uppercase tracking-[0.24em] text-[color:var(--axial-muted)]">Teléfono</p>
              <a href="tel:+573001234567" class="contact-link mt-2 inline-block font-display text-[1.25rem] tracking-[-0.03em] text-secondary">
                +57 300 123 4567
              </a>
            </div>
            <div>
              <p class="text-sm uppercase tracking-[0.24em] text-[color:var(--axial-muted)]">Dirección</p>
              <p class="mt-2 text-base leading-7 text-secondary/90">
                Calle 93 #14-25, Consultorio 402<br />
                Bogotá, Colombia
              </p>
