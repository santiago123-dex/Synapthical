          </div>
        </div>

        <div class="reveal-view overflow-hidden rounded-[1.5rem] border border-[color:var(--axial-border)]">
          <iframe
            title="Mapa de AXIAL en Bogotá"
            src="https://maps.google.com/maps?q=Calle%2093%20%2314-25%2C%20Bogot%C3%A1&t=&z=15&ie=UTF8&iwloc=&output=embed"
            class="h-[320px] w-full bg-secondary sm:h-[380px] lg:h-full lg:min-h-[440px]"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
