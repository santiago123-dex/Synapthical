---
const sponsors = [
  'Club Altura',
  'Runlab Bogotá',
  'Studio Norte',
  'Liga Capital',
  'Ciclo 93',
  'Axis Performance',
];

const repeatedSponsors = [...sponsors, ...sponsors, ...sponsors];
---

<section id="patrocinadores" class="-mt-px py-0">
  <div class="scroll-stage theme-dark relative left-1/2 w-screen -translate-x-1/2 overflow-hidden border-y border-[color:var(--axial-border)] bg-primary py-4 sm:py-5">
    <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-14 bg-gradient-to-r from-primary to-transparent sm:w-24"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-14 bg-gradient-to-l from-primary to-transparent sm:w-24"></div>

    <div class="flex items-center gap-6 px-4 sm:gap-8 sm:px-6 lg:px-10">
      <p class="shrink-0 text-[0.64rem] uppercase tracking-[0.3em] text-[color:var(--axial-muted)] sm:text-[0.68rem]">
        Patrocinadores y aliados
      </p>

      <div class="marquee-shell min-w-0 flex-1 text-secondary">
        <div class="marquee-track">
          {repeatedSponsors.map((name, index) => (
            <span class="marquee-pill" aria-hidden={index >= sponsors.length}>{name}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
