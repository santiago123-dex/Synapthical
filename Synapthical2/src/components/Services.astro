---
const services = [
  {
    index: '01',
    title: 'Rehabilitación deportiva',
    copy: 'Volver a entrenar con control y confianza.',
  },
  {
    index: '02',
    title: 'Terapia manual',
    copy: 'Movilidad y alivio sin perder precisión clínica.',
  },
  {
    index: '03',
    title: 'Reeducación postural',
    copy: 'Mejor postura para el trabajo y la vida diaria.',
  },
  {
    index: '04',
    title: 'Punción seca',
    copy: 'Apoyo puntual para dolor muscular y puntos gatillo.',
  },
];
---

<section id="servicios" class="cut-top relative px-0 py-20 sm:py-24 lg:py-28">
  <div class="section-shell">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)] lg:gap-10">
      <div class="reveal-view">
        <span class="section-kicker">Servicios</span>
        <h2 class="section-title mt-6 max-w-lg">
          Lo esencial para recuperar movilidad.
        </h2>
        <p class="section-copy mt-5 max-w-md">
          Servicios concretos, tratamientos claros y menos ruido.
        </p>
      </div>

      <div class="space-y-4 lg:space-y-0">
        {services.map((service, idx) => (
          <article
            class:list={[
              'reveal-view group relative border-t border-[color:var(--axial-border)] py-6 sm:py-7',
              idx % 2 === 1 ? 'lg:ml-16' : 'lg:mr-16',
            ]}
          >
            <div class="grid gap-4 sm:grid-cols-[5rem_minmax(0,1fr)] sm:gap-8">
              <p class="font-display text-[1.6rem] leading-none tracking-[-0.08em] text-[color:var(--axial-muted)] transition-colors duration-300 group-hover:text-primary">
                {service.index}
              </p>
              <div>
                <h3 class="font-display text-[clamp(1.35rem,2vw,2rem)] leading-[1] tracking-[-0.04em] text-primary">
                  {service.title}
                </h3>
                <p class="mt-3 max-w-xl text-[0.98rem] leading-7 text-[color:var(--axial-muted)]">
                  {service.copy}
                </p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
