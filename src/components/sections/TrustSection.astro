---
import type { SiteConfig } from '../../data/site';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---

<section class="section-shell pt-0">
  <div class="shell rounded-[2rem] border border-[var(--color-border)] bg-white p-8 shadow-[0_26px_60px_rgba(18,22,29,0.06)] md:p-10">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:items-start">
      <div>
        <span class="section-kicker">{site.trust.eyebrow}</span>
        <h2 class="mt-4 font-display text-4xl font-semibold tracking-[-0.05em] text-[var(--color-primary)] md:text-5xl">
          {site.trust.title}
        </h2>
        <p class="mt-5 max-w-xl text-lg leading-8 text-[var(--color-muted)]">{site.trust.intro}</p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {site.trust.items.map((item) => (
          <article class="border-t border-[var(--color-border)] pt-5">
            <h3 class="font-display text-2xl font-semibold tracking-[-0.04em] text-[var(--color-primary)]">{item.title}</h3>
            <p class="mt-3 text-base leading-7 text-[var(--color-muted)]">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
