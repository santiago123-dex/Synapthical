---
import type { SiteConfig } from '../../data/site';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---

<section class="section-shell pb-0">
  <div class="shell grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start lg:gap-16">
    <div>
      <span class="section-kicker">{site.trust.eyebrow}</span>
      <h2 class="section-title mt-4 max-w-[14ch]">{site.trust.title}</h2>
      <p class="mt-6 max-w-xl text-lg leading-8 text-[var(--color-muted)]">{site.trust.intro}</p>
    </div>

    <div class="grid gap-5">
      {site.trust.quickFacts.map((item) => (
        <article class="trust-row grid gap-3 border-b border-[var(--color-border)] pb-5 last:border-b-0 last:pb-0 md:grid-cols-[12rem_minmax(0,1fr)] md:gap-6">
          <h3 class="text-xl font-semibold tracking-[-0.03em] text-[var(--color-primary)]">{item.title}</h3>
          <p class="text-base leading-7 text-[var(--color-muted)]">{item.description}</p>
        </article>
      ))}
    </div>
  </div>

  <div class="shell mt-12 rounded-[1.75rem] border border-[var(--color-border)] bg-white px-6 py-7 shadow-[0_18px_42px_rgba(13,27,42,0.05)] md:px-8 md:py-8">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,0.72fr)_minmax(0,1.28fr)] lg:items-start">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[var(--color-accent)]">Ideal para</p>
        <p class="mt-3 max-w-sm text-base leading-7 text-[var(--color-muted)]">
          Pacientes que necesitan alivio del dolor, una explicación clara de su caso y una ruta segura para volver a moverse.
        </p>
      </div>

      <ul class="grid gap-3 md:grid-cols-3">
        {site.trust.audiences.map((item) => (
          <li class="rounded-[1.25rem] bg-[color:rgba(13,27,42,0.03)] px-4 py-4 text-sm leading-6 text-[var(--color-text)]">{item}</li>
        ))}
      </ul>
    </div>
  </div>
</section>
