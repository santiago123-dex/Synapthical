---
import type { SiteConfig } from '../../data/site';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
const [featured, ...rest] = site.testimonials.items;
---

<section id="resultados" class="section-shell">
  <div class="shell grid gap-10 lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] lg:gap-16">
    <div>
      <span class="section-kicker">{site.testimonials.eyebrow}</span>
      <h2 class="section-title mt-4 max-w-[14ch]">{site.testimonials.title}</h2>
      <p class="mt-6 max-w-xl text-lg leading-8 text-[var(--color-muted)]">{site.testimonials.intro}</p>
    </div>

    <div class="grid gap-5">
      <article class="overflow-hidden rounded-[1.95rem] border border-[color:rgba(255,255,255,0.08)] bg-[linear-gradient(135deg,#0D1B2A_0%,#16364D_100%)] p-7 text-white shadow-[0_24px_64px_rgba(13,27,42,0.18)] md:p-8">
        <div class="mb-5 flex gap-1 text-[var(--color-secondary)]" aria-hidden="true">
          <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
        </div>
        <p class="max-w-3xl text-xl leading-8 tracking-[-0.02em] md:text-2xl md:leading-10">“{featured.quote}”</p>
        <div class="mt-6 grid gap-3 border-t border-white/12 pt-5 md:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]">
          <div>
            <p class="text-lg font-semibold text-white">{featured.name}</p>
            <p class="mt-1 text-sm text-white/68">{featured.sportOrCondition}</p>
          </div>
          <div class="grid gap-2 md:justify-items-end">
            {featured.timeframe && <p class="text-sm text-white/68">{featured.timeframe}</p>}
            <p class="text-sm leading-6 text-white">{featured.result}</p>
          </div>
        </div>
      </article>

      <div class="grid gap-5 md:grid-cols-2">
        {rest.map((item) => (
          <article class="flex h-full flex-col rounded-[1.6rem] border border-[var(--color-border)] bg-white p-6 shadow-[0_16px_36px_rgba(13,27,42,0.05)]">
            <div class="mb-4 flex gap-1 text-[var(--color-secondary)]" aria-hidden="true">
              <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
            </div>
            <p class="text-base leading-7 text-[var(--color-primary)]">“{item.quote}”</p>
            <div class="mt-auto border-t border-[var(--color-border)] pt-4">
              <p class="font-semibold tracking-[-0.02em] text-[var(--color-primary)]">{item.name}</p>
              <p class="mt-1 text-sm text-[var(--color-muted)]">{item.sportOrCondition}</p>
              {item.timeframe && <p class="mt-3 text-sm text-[var(--color-accent)]">{item.timeframe}</p>}
              <p class="mt-2 text-sm leading-6 text-[var(--color-text)]">{item.result}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
