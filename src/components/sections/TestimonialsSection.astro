---
import type { SiteConfig } from '../../data/site';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---

<section id="resultados" class="section-shell bg-[linear-gradient(180deg,rgba(31,175,196,0.04)_0%,rgba(255,255,255,0)_100%)]">
  <div class="shell grid gap-10 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] lg:gap-16">
    <div>
      <span class="section-kicker">{site.testimonials.eyebrow}</span>
      <h2 class="section-title mt-4 max-w-xl">{site.testimonials.title}</h2>
      <p class="mt-6 max-w-xl text-lg leading-8 text-[var(--color-muted)]">{site.testimonials.intro}</p>
    </div>

    <div class="grid gap-5 md:grid-cols-3">
      {site.testimonials.items.map((item) => (
        <article class="rounded-[1.75rem] border border-[var(--color-border)] bg-white p-6 shadow-[0_18px_40px_rgba(18,22,29,0.05)]">
          <div class="mb-5 flex gap-1 text-[var(--color-secondary)]" aria-hidden="true">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <p class="text-base leading-7 text-[var(--color-primary)]">“{item.quote}”</p>
          <div class="mt-6 border-t border-[var(--color-border)] pt-4">
            <p class="font-display text-lg font-semibold tracking-[-0.03em] text-[var(--color-primary)]">{item.name}</p>
            <p class="mt-1 text-sm text-[var(--color-muted)]">{item.context}</p>
            <p class="mt-3 text-sm leading-6 text-[var(--color-accent)]">{item.outcome}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
