---
import type { SiteConfig } from '../../data/site';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---

<section id="servicios" class="section-shell">
  <div class="shell grid gap-12 lg:grid-cols-[minmax(0,0.84fr)_minmax(0,1.16fr)] lg:gap-16">
    <div>
      <span class="section-kicker">{site.services.eyebrow}</span>
      <h2 class="section-title mt-4 max-w-[14ch]">{site.services.title}</h2>
      <p class="mt-6 max-w-xl text-lg leading-8 text-[var(--color-muted)]">{site.services.intro}</p>
    </div>

    <div class="grid gap-5">
      {site.services.featuredItems.map((service, index) => (
        <article class="service-feature rounded-[1.85rem] border border-[var(--color-border)] bg-white p-6 shadow-[0_20px_48px_rgba(13,27,42,0.05)] md:p-8">
          <div class="grid gap-6 md:grid-cols-[auto_minmax(0,1fr)] md:gap-8">
            <div class="flex items-start gap-4 md:block">
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-[color:rgba(25,167,198,0.12)] text-sm font-semibold text-[var(--color-secondary)]">
                0{index + 1}
              </span>
            </div>

            <div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_18rem] lg:gap-8">
              <div>
                <h3 class="text-2xl font-semibold tracking-[-0.04em] text-[var(--color-primary)] md:text-[2rem]">{service.title}</h3>
                <p class="mt-4 text-base leading-7 text-[var(--color-muted)]">{service.description}</p>
                <p class="mt-4 text-sm leading-6 text-[var(--color-text)]"><strong>Ideal para:</strong> {service.forWho}</p>
              </div>

              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-accent)]">Qué buscamos</p>
                <ul class="mt-3 grid gap-3 text-sm leading-6 text-[var(--color-muted)]">
                  {service.outcomes.map((item) => (
                    <li class="flex gap-3">
                      <span class="mt-2 h-2 w-2 rounded-full bg-[var(--color-secondary)]"></span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>

  <div class="shell mt-12 grid gap-6 rounded-[1.75rem] border border-[var(--color-border)] bg-[linear-gradient(180deg,#ffffff_0%,rgba(25,167,198,0.03)_100%)] px-6 py-7 md:px-8 md:py-8 lg:grid-cols-[minmax(0,0.72fr)_minmax(0,1.28fr)] lg:items-start">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[var(--color-accent)]">También podemos ayudarte con</p>
      <p class="mt-3 max-w-sm text-base leading-7 text-[var(--color-muted)]">
        Servicios complementarios para prevenir recaídas, entender mejor el origen del dolor y volver al deporte con criterios claros.
      </p>
    </div>

    <ul class="grid gap-3 md:grid-cols-3">
      {site.services.secondaryItems.map((item) => (
        <li class="rounded-[1.2rem] border border-[var(--color-border)] bg-white px-4 py-4 text-sm leading-6 text-[var(--color-text)]">{item}</li>
      ))}
    </ul>
  </div>
</section>
