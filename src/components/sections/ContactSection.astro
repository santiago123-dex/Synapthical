---
import type { SiteConfig } from '../../data/site';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---

<section id="contacto" class="section-shell pt-0">
  <div class="shell overflow-hidden rounded-[2.2rem] border border-[color:rgba(255,255,255,0.08)] bg-[linear-gradient(135deg,#0D1B2A_0%,#112F45_58%,#17627D_100%)] px-6 py-10 text-white shadow-[0_32px_90px_rgba(13,27,42,0.18)] md:px-10 md:py-14 lg:px-12">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(320px,0.86fr)] lg:items-start">
      <div>
        <span class="eyebrow eyebrow-dark">{site.contact.eyebrow}</span>
        <h2 class="mt-4 max-w-2xl text-4xl font-semibold tracking-[-0.05em] md:text-5xl">{site.contact.title}</h2>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-white/74">{site.contact.description}</p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            href={site.contact.whatsappHref}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center gap-3 rounded-full bg-[var(--color-secondary)] px-6 py-4 text-base font-semibold text-white transition hover:translate-y-[-1px] hover:shadow-[0_18px_40px_rgba(25,167,198,0.28)]"
          >
            Hablar por WhatsApp
            <span aria-hidden="true">↗</span>
          </a>
          <p class="text-sm leading-6 text-white/62">Te orientamos y te ayudamos a reservar tu valoración.</p>
        </div>
      </div>

      <div class="grid gap-5 rounded-[1.6rem] border border-white/10 bg-white/[0.05] p-6 backdrop-blur-md">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-white/45">WhatsApp / llamada</p>
          <a href={site.contact.phoneHref} class="mt-2 block text-xl font-semibold text-white transition hover:text-[var(--color-secondary)]">
            {site.contact.phoneDisplay}
          </a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-white/45">Dirección</p>
          <a
            href={site.contact.mapHref}
            target="_blank"
            rel="noreferrer"
            class="mt-2 block text-base leading-7 text-white/80 transition hover:text-white"
          >
            {site.contact.address}
          </a>
        </div>
        <div class="grid gap-1">
          <p class="text-xs uppercase tracking-[0.2em] text-white/45">Horario</p>
          {site.contact.schedule.map((item) => <p class="text-base text-white/80">{item}</p>)}
        </div>
        <div class="grid gap-2 border-t border-white/10 pt-5 text-sm text-white/70 sm:grid-cols-2">
          <a href={site.contact.instagramHref} target="_blank" rel="noreferrer" class="transition hover:text-[var(--color-secondary)]">
            {site.contact.instagramHandle}
          </a>
          <a href={site.contact.emailHref} class="transition hover:text-[var(--color-secondary)]">{site.contact.email}</a>
        </div>
      </div>
    </div>
  </div>
</section>
