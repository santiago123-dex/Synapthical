---
import type { SiteConfig } from '../../data/site';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---

<section id="proceso" class="section-shell">
  <div class="shell overflow-hidden rounded-[2.2rem] border border-[color:rgba(255,255,255,0.08)] bg-[linear-gradient(135deg,#0D1B2A_0%,#0F2438_100%)] px-6 py-10 text-white shadow-[0_28px_80px_rgba(13,27,42,0.16)] md:px-10 md:py-12 lg:px-12 lg:py-14">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] lg:items-start lg:gap-16">
      <div>
        <span class="eyebrow eyebrow-dark">{site.process.eyebrow}</span>
        <h2 class="mt-4 max-w-xl text-4xl font-semibold leading-[0.98] tracking-[-0.05em] md:text-5xl">{site.process.title}</h2>
        <p class="mt-5 max-w-xl text-lg leading-8 text-white/72">{site.process.intro}</p>
      </div>

      <div class="grid gap-5">
        {site.process.steps.map((item) => (
          <article class="grid gap-4 rounded-[1.5rem] border border-white/10 bg-white/[0.04] p-5 md:grid-cols-[5rem_minmax(0,1fr)] md:items-start md:gap-5 md:p-6">
            <span class="text-3xl font-semibold tracking-[-0.05em] text-[var(--color-secondary)] md:text-4xl">{item.step}</span>
            <div>
              <h3 class="text-2xl font-semibold tracking-[-0.03em] text-white">{item.title}</h3>
              <p class="mt-3 text-base leading-7 text-white/72">{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
