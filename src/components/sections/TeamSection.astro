---
import type { SiteConfig } from '../../data/site';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---

<section id="equipo" class="section-shell">
  <div class="shell grid gap-10 lg:grid-cols-[minmax(0,0.88fr)_minmax(0,1.12fr)] lg:gap-16">
    <div>
      <span class="section-kicker">{site.team.eyebrow}</span>
      <h2 class="section-title mt-4 max-w-[14ch]">{site.team.title}</h2>
      <p class="mt-6 max-w-xl text-lg leading-8 text-[var(--color-muted)]">{site.team.intro}</p>
    </div>

    <div class="grid gap-5 md:grid-cols-3">
      {site.team.members.map((member) => (
        <article class="rounded-[1.7rem] border border-[var(--color-border)] bg-white p-6 shadow-[0_18px_42px_rgba(13,27,42,0.05)]">
          <div class="flex items-center gap-4">
            {member.photo ? (
              <img src={member.photo} alt={member.name} class="h-16 w-16 rounded-full object-cover" />
            ) : (
              <div class="grid h-16 w-16 place-items-center rounded-full bg-[linear-gradient(135deg,#0D1B2A_0%,#19496B_100%)] text-lg font-semibold text-white">
                {member.initials}
              </div>
            )}

            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-accent)]">{member.yearsExperience}</p>
              <h3 class="mt-1 text-xl font-semibold tracking-[-0.03em] text-[var(--color-primary)]">{member.name}</h3>
              <p class="text-sm text-[var(--color-muted)]">{member.role}</p>
            </div>
          </div>

          <div class="mt-5">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-accent)]">Especialidad</p>
            <p class="mt-2 text-base leading-7 text-[var(--color-text)]">{member.specialty}</p>
          </div>

          <p class="mt-5 text-base leading-7 text-[var(--color-muted)]">{member.focus}</p>

          <div class="mt-5 grid gap-4 border-t border-[var(--color-border)] pt-5">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-accent)]">Enfoque clínico</p>
              <ul class="mt-3 grid gap-2 text-sm leading-6 text-[var(--color-muted)]">
                {member.credentials.map((item) => (
                  <li class="flex gap-3">
                    <span class="mt-2 h-2 w-2 rounded-full bg-[var(--color-secondary)]"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-accent)]">Credenciales</p>
              <ul class="mt-3 flex flex-wrap gap-2">
                {member.licensesOrCertifications.map((item) => (
                  <li class="rounded-full bg-[color:rgba(13,27,42,0.05)] px-3 py-2 text-xs font-medium text-[var(--color-text)]">{item}</li>
                ))}
              </ul>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
