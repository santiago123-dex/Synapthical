---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/sections/Header.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import TrustSection from '../components/sections/TrustSection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import ServicesSection from '../components/sections/ServicesSection.astro';
import TeamSection from '../components/sections/TeamSection.astro';
import ContactSection from '../components/sections/ContactSection.astro';
import FloatingCTA from '../components/sections/FloatingCTA.astro';
import { site } from '../data/site';
---

<BaseLayout>
  <div class="min-h-screen bg-[var(--color-surface)] text-[var(--color-text)]">
    <Header site={site} />
    <main>
      <HeroSection site={site} />
      <TrustSection site={site} />
      <ServicesSection site={site} />
      <AboutSection site={site} />
      <TeamSection site={site} />
      <ContactSection site={site} />
    </main>
    <footer class="border-t border-[var(--color-border)] py-8 text-sm text-[var(--color-muted)]">
      <div class="shell flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
        <p>{site.footer.text}</p>
        <p>{site.brand.locationLabel} · Atención presencial con agenda previa.</p>
      </div>
    </footer>
    <FloatingCTA site={site} />
  </div>
</BaseLayout>
